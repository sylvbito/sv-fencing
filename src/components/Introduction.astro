---
interface Props {
  headline?: string;
  body?: string;
}

const {
  headline = 'Built around quality, care, and accountability.',
  body = 'We have been serving clients from our workshop for over a decade. Every project begins with a conversation — about how you use the space, what matters to you, and how you want the result to feel. We handle the full process in-house: consultation, design, production, and installation. No subcontractors, no hand-offs. Just a single team accountable for the result.'
} = Astro.props;
---

<section class="introduction">
  <div class="container">
    <div class="introduction__grid">
      <h2 class="introduction__headline">{headline}</h2>
      <div class="introduction__body">
        <p>{body}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .introduction {
    padding-block: var(--section-y);
  }

  .introduction__grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
  }

  .introduction__headline {
    font-size: var(--text-xl);
    font-weight: 500;
    line-height: 1.2;
    margin: 0;
    color: var(--color-heading);
  }

  .introduction__body p {
    font-size: var(--text-md);
    line-height: 1.75;
    color: var(--color-text-muted);
    margin: 0;
    max-width: 44rem;
  }

  @media (max-width: 720px) {
    .introduction__grid {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
  }
</style>
