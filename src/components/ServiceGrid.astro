---
interface Service {
  id?: string;
  data: {
    title: string;
    summary: string;
  };
}

interface Props {
  services: Service[];
  variant?: 'grid' | 'list' | 'featured-first' | 'icon-grid';
}

const { services, variant = 'grid' } = Astro.props;
const pathFor = (service: Service) => `/services/${service.id}/`;

const fallbackIcons = [
  `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="6" width="18" height="12" rx="1"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="7" y1="3" x2="7" y2="6"/><line x1="17" y1="3" x2="17" y2="6"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12h8M8 12a4 4 0 0 1 8 0"/><path d="M12 8v8"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 3v18"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`
];
---

{ variant === 'icon-grid' ? (
  <div class="service-grid service-grid--icon-grid" data-theme="dark">
    {services.map((service, i) => (
      <a class="service-icon-card" href={pathFor(service)}>
        <span class="service-icon-card__icon" set:html={fallbackIcons[i % fallbackIcons.length]} />
        <h3>{service.data.title}</h3>
        <p>{service.data.summary}</p>
      </a>
    ))}
  </div>
) : (
  <div class:list={['service-grid', `service-grid--${variant}`]}>
    {services.map((service) => (
      <a class="service-card" href={pathFor(service)}>
        <h3>{service.data.title}</h3>
        <p>{service.data.summary}</p>
        <span>Read more</span>
      </a>
    ))}
  </div>
) }

<style>
  .service-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-5);
  }

  .service-grid--list {
    grid-template-columns: 1fr;
  }

  .service-grid--list .service-card {
    display: grid;
    grid-template-columns: minmax(10rem, 0.45fr) minmax(0, 1fr) auto;
    gap: var(--space-5);
    align-items: start;
    min-height: auto;
  }

  .service-grid--featured-first .service-card:first-child {
    grid-column: span 2;
    min-height: 20rem;
    background: var(--color-section);
  }

  .service-card {
    display: flex;
    min-height: 17rem;
    flex-direction: column;
    justify-content: space-between;
    padding: var(--space-5);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-md);
    color: inherit;
    text-decoration: none;
  }

  /* Center orphaned items on last row for uneven grid counts */
  .service-grid--grid > :nth-child(4):nth-last-child(2) {
    grid-column: 1;
    justify-self: end;
    width: calc(50% - var(--space-5) / 2);
    min-width: 280px;
  }

  .service-grid--grid > :nth-child(4):nth-last-child(2) ~ :nth-child(5) {
    grid-column: 2;
    justify-self: start;
    width: calc(50% - var(--space-5) / 2);
    min-width: 280px;
  }

  .service-card:hover {
    border-color: var(--color-text);
  }

  .service-card h3 {
    margin-bottom: var(--space-4);
  }

  .service-card p {
    flex: 1;
  }

  .service-card span {
    color: var(--color-link);
    font-size: var(--text-sm);
    font-weight: 700;
  }

  /* --- icon-grid variant --- */

  .service-grid--icon-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0;
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .service-icon-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-7) var(--space-5);
    text-decoration: none;
    color: inherit;
    transition: background 0.2s;
  }

  .service-icon-card:hover {
    background: var(--color-section);
  }

  .service-icon-card + .service-icon-card {
    border-left: 1px solid var(--color-rule);
  }

  .service-icon-card__icon {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    width: 2rem;
    height: 2rem;
    color: var(--color-icon-accent);
    flex-shrink: 0;
  }

  .service-icon-card__icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .service-grid--icon-grid h3 {
    margin: 0;
    font-size: var(--text-lg);
    font-weight: 700;
  }

  .service-grid--icon-grid p {
    margin: 0;
    font-size: var(--text-sm);
    line-height: 1.55;
  }

  @media (max-width: 860px) {
    .service-grid {
      grid-template-columns: 1fr;
    }

    .service-grid--list .service-card {
      display: flex;
    }

    .service-grid--featured-first .service-card:first-child {
      grid-column: auto;
    }

    .service-grid--icon-grid {
      grid-template-columns: 1fr 1fr;
    }

    .service-icon-card:nth-child(3) {
      border-left: none;
    }
  }

  @media (max-width: 540px) {
    .service-grid--icon-grid {
      grid-template-columns: 1fr;
    }

    .service-icon-card + .service-icon-card {
      border-left: none;
      border-top: 1px solid var(--color-rule);
    }
  }
</style>
