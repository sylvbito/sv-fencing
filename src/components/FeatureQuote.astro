---
interface Props {
  quote?: string;
  name?: string;
  role?: string;
}

const {
  quote = 'Working with this team was the best decision we made during our renovation. The quality of the work is outstanding — every detail was considered, every finish is flawless. Two years later and it still looks like it was installed yesterday.',
  name = 'Client Name',
  role = 'Project type, Suburb'
} = Astro.props;
---

<section class="feature-quote">
  <div class="container container--narrow">
    <figure class="feature-quote__figure">
      <blockquote>
        <p>{quote}</p>
      </blockquote>
      <figcaption>
        <strong>{name}</strong>
        {role && <span>{role}</span>}
      </figcaption>
    </figure>
  </div>
</section>

<style>
  .feature-quote {
    padding-block: var(--section-y);
    background: var(--color-section);
  }

  .feature-quote__figure {
    margin: 0;
    text-align: center;
  }

  .feature-quote__figure blockquote {
    margin: 0 0 var(--space-6);
  }

  .feature-quote__figure blockquote p {
    font-size: var(--text-xl);
    font-weight: 400;
    line-height: 1.5;
    color: var(--color-heading);
    margin: 0;
    quotes: none;
  }

  .feature-quote__figure figcaption {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .feature-quote__figure figcaption strong {
    color: var(--color-heading);
    font-weight: 600;
  }
</style>
