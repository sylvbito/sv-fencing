---
interface LogoItem {
  label: string;
  icon?: string;
}

interface Props {
  logos?: (string | LogoItem)[];
}

const { logos = ['Local partner', 'Industry body', 'Community group', 'Supplier'] } = Astro.props;

const fallbackIcons: Record<string, string> = {
  'Australian Made': `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
  'Licensed': `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>`,
  'CCA-Treated': `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 10c.5-.5 1-1.5 1-3 0-2.5-2-4-4-4-1.6 0-3 .9-3.7 2.3"/><path d="M7 10c-.5-.5-1-1.5-1-3 0-2.5 2-4 4-4 2.2 0 3.9 1.7 4 3.9"/><path d="M12 21V9"/><path d="M8 21v-6"/><path d="M16 21v-6"/></svg>`,
  'Free': `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7V5c0-1.1.9-2 2-2h2"/><path d="M17 3h2c1.1 0 2 .9 2 2v2"/><path d="M21 17v2c0 1.1-.9 2-2 2h-2"/><path d="M7 21H5c-1.1 0-2-.9-2-2v-2"/><line x1="7" y1="12" x2="17" y2="12"/><line x1="12" y1="7" x2="12" y2="17"/></svg>`,
};
---

<div class="logo-strip" aria-label="Associated organisations">
  {logos.map((logo) => {
    const label = typeof logo === 'string' ? logo : logo.label;
    const iconKey = Object.keys(fallbackIcons).find(k => label.startsWith(k));
    const iconSvg = typeof logo === 'object' && logo.icon ? logo.icon : (iconKey ? fallbackIcons[iconKey] : null);
    return (
      <span>
        {iconSvg && <span class="logo-strip__icon" set:html={iconSvg} />}
        <span set:html={label.replace(/\n/g, '<br>')} />
      </span>
    );
  })}
</div>

<style>
  .logo-strip {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    background: var(--color-page);
  }

  .logo-strip span {
    display: grid;
    min-height: 6.5rem;
    place-items: center;
    padding: var(--space-5) var(--space-4);
    color: var(--color-text);
    font-size: var(--text-sm);
    font-weight: 700;
    text-align: center;
    gap: var(--space-3);
  }

  .logo-strip__icon {
    color: var(--brand-primary);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo-strip__icon :global(svg) {
    width: 32px;
    height: 32px;
  }

  @media (max-width: 860px) {
    .logo-strip {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
