---
interface Props {
  items?: Array<{ title: string; description?: string; imageUrl?: string }>;
  variant?: 'grid' | 'portfolio';
}

const {
  variant = 'portfolio',
  items = [
    { title: 'Project image', description: 'Swap this placeholder for client photography.' },
    { title: 'Detail image', description: 'Use captions when context matters.' },
    { title: 'Team image', description: 'Keep image treatment simple and consistent.' }
  ]
} = Astro.props;

// Resolve image URLs with base path for GitHub Pages subdirectory deployment
const resolveUrl = (url) => {
  if (!url) return url;
  return url.startsWith('/') && !url.startsWith(import.meta.env.BASE_URL)
    ? import.meta.env.BASE_URL.replace(/\/$/, '') + url
    : url;
};

const portfolioItems = items.length >= 4
  ? items
  : [
    { title: 'Residential Project', description: 'Herringbone oak, Malvern' },
    { title: 'Commercial Fit-out', description: 'Wide-board blackbutt, CBD' },
    { title: 'Heritage Restore', description: 'Baltic pine, Carlton North' },
    { title: 'Custom Stain', description: 'European oak, Toorak' }
  ];
---

{ variant === 'portfolio' ? (
  <div class="gallery-block gallery-block--portfolio">
    <div class="portfolio-track">
      {portfolioItems.map((item) => (
        <figure class="portfolio-card">
          {item.imageUrl ? (
            <img src={resolveUrl(item.imageUrl)} alt={item.title} loading="lazy" />
          ) : (
            <div aria-hidden="true"></div>
          )}
          <figcaption>
            <strong>{item.title}</strong>
            {item.description && <span>{item.description}</span>}
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
) : (
  <div class:list={['gallery-block', `gallery-block--${variant}`]}>
    {items.map((item) => (
      <figure>
        {item.imageUrl ? (
          <img src={resolveUrl(item.imageUrl)} alt={item.title} loading="lazy" />
        ) : (
          <div aria-hidden="true"></div>
        )}
        <figcaption>
          <strong>{item.title}</strong>
          {item.description && <span>{item.description}</span>}
        </figcaption>
      </figure>
    ))}
  </div>
) }

<style>
  .gallery-block {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-5);
  }

  .gallery-block--portfolio {
    display: block;
  }

  .portfolio-track {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-2);
  }

  .portfolio-card {
    margin: 0;
  }

  .portfolio-card > img {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    display: block;
    border-radius: var(--radius-xs);
  }

  .portfolio-card > div {
    aspect-ratio: 3 / 4;
    border-radius: var(--radius-xs);
    background:
      linear-gradient(135deg, transparent 48%, var(--color-rule) 49%, transparent 51%),
      linear-gradient(45deg, transparent 48%, var(--color-rule) 49%, transparent 51%),
      var(--color-section);
  }

  .portfolio-card figcaption {
    margin-top: var(--space-3);
  }

  figure {
    margin: 0;
  }

  figure > img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius-md);
  }

  figure > div {
    aspect-ratio: 4 / 3;
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-md);
    background:
      linear-gradient(135deg, transparent 49%, var(--color-rule) 50%, transparent 51%),
      linear-gradient(45deg, transparent 49%, var(--color-rule) 50%, transparent 51%),
      var(--color-section);
  }

  figcaption {
    display: grid;
    gap: var(--space-1);
    margin-top: var(--space-3);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  figcaption strong {
    color: var(--color-text);
  }

  @media (max-width: 860px) {
    .gallery-block {
      grid-template-columns: 1fr;
    }

    .portfolio-track {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 480px) {
    .portfolio-track {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
