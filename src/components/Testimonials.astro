---
interface Testimonial {
  data: {
    quote: string;
    name: string;
    role?: string;
    stars?: number;
  };
}

interface Props {
  testimonials: Testimonial[];
  variant?: 'grid' | 'stacked';
}

const { testimonials, variant = 'grid' } = Astro.props;
---

<div class:list={['testimonials', `testimonials--${variant}`]}>
  {testimonials.map((item) => (
    <figure>
      <div class="stars" aria-label={`${item.data.stars ?? 5} out of 5 stars`}>
        {Array.from({ length: 5 }, (_, i) => (
          <svg width="18" height="18" viewBox="0 0 20 20" fill={i < (item.data.stars ?? 5) ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="1.5">
            <path d="M10 1.5l2.39 4.84 5.34.78-3.87 3.77.91 5.33L10 13.88l-4.77 2.51.91-5.33-3.87-3.77 5.34-.78L10 1.5z"/>
          </svg>
        ))}
      </div>
      <blockquote>{item.data.quote}</blockquote>
      <figcaption>
        <strong>{item.data.name}</strong>
        {item.data.role && <span>{item.data.role}</span>}
        <span class="source">via Google</span>
      </figcaption>
    </figure>
  ))}
</div>

<style>
  .testimonials {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-5);
  }

  .testimonials--stacked {
    grid-template-columns: 1fr;
    max-width: var(--container-narrow);
  }

  figure {
    margin: 0;
    padding: var(--space-5);
    background: var(--color-soft);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-subtle);
  }

  .stars {
    display: flex;
    gap: 2px;
    margin-bottom: var(--space-4);
    color: #f5a623;
  }

  blockquote {
    margin: 0 0 var(--space-5);
    color: var(--color-text);
    font-size: var(--text-md);
    line-height: 1.55;
  }

  figcaption {
    display: grid;
    gap: var(--space-1);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  figcaption strong {
    color: var(--color-text);
  }

  .source {
    display: block;
    margin-top: var(--space-2);
    color: var(--color-link);
    font-size: var(--text-xs);
    font-weight: 600;
    font-style: normal;
  }

  @media (max-width: 860px) {
    .testimonials {
      grid-template-columns: 1fr;
      max-width: 36rem;
      margin-inline: auto;
    }
  }
</style>
