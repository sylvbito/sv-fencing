---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageIntro from '@components/PageIntro.astro';
import Section from '@components/Section.astro';
---

<BaseLayout title="Privacy" description="Privacy policy for Client Name.">
  <PageIntro
    eyebrow="Privacy"
    title="Privacy policy"
    intro="This page explains how we collect, use, and protect your personal information."
  />

  <Section narrow>
    <div class="prose">
      <h2>Information collected</h2>
      <p>
        We collect information you provide through our contact form, including your name, email address, phone number,
        and project details. We also collect standard web analytics data (page views, browser type, referral source)
        through our hosting provider.
      </p>

      <h2>How information is used</h2>
      <p>
        Contact information is used to respond to enquiries, provide quotes, and communicate about your project.
        Analytics data helps us improve the website. We do not sell or share personal information with third parties
        for marketing purposes.
      </p>

      <h2>Data storage and retention</h2>
      <p>
        Enquiry submissions are stored securely and retained for the duration of your project plus a reasonable period
        afterward for warranty and follow-up purposes. You may request deletion of your data at any time by contacting us.
      </p>

      <h2>Contact</h2>
      <p>
        For privacy-related enquiries, contact us at our listed email address or phone number.
      </p>
    </div>
  </Section>
</BaseLayout>
